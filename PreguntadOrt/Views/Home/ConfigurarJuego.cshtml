@{
    ViewData["Title"] = "Configurar Juego";
}

 
<div class="container" style="width:800px;">
    <div class="row">
            <div class="col bg-white">
<div class="text-center">
    <img src = "https://pbs.twimg.com/media/Fb5HMe5XkAMY2Yj?format=png&name=small">
</div>
<form action='@Url.Action("Comenzar","Home")' method="get">
  <center>
    <div class="form-group col-6">  
      <div class="mb-5">
        <h6>Nombre de usuario</h6>
          <input class="form-control" type="text" name="username" required autocomplete ="off" placeholder="Ej: fod123">
        </div>
        <div class="mb-5">
              <h6>Dificultad</h6>
              <select name = "dificultad" class="form-control" id="exampleFormControlSelect1">
                @foreach (Dificultad p in ViewBag.dificultades)  
                  {
                    <option value="@p.IdDificultad">@p.Nombre</option>
                  }      
              </select>
        </div>
        <div class="mb-5">             
          <h6>Categorias:</h6>
              @foreach (Categoria p in ViewBag.categorias)  
                {
                  <div class="form-check form-check-inline">
                    <div> 
                      <img src =@p.Foto height = "50px">
                    </div>
                    <input class="form-check-input" type="radio" name="categoria" id="exampleRadios1" value="@p.IdCategoria" checked>    
                    <label name="categoria" for="exampleRadios1"> @p.Nombre                     
                  </div>
                }
          </div> 
      </form>                       
      <div><center><button style="margin-top:15px;" type="submit" class="btn btn-primary">Jugar</button></div> <br/>       
          </div>
          </div>  
          </center>
     </div>
    </div>
 </div>

     